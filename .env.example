# ============================================================
# Zerto SIEM Bridge — environment configuration
# Copy to .env and populate for your deployment
# ============================================================

# --- TLS -------------------------------------------------------
# Set to false to accept plain syslog on 514 (not recommended in production)
TLS_ENABLED=true

# Strong random passphrase for the private key.
# Generate with: openssl rand -base64 48
FLUENTD_TLS_KEY_PASSPHRASE=REPLACE_WITH_STRONG_PASSPHRASE

# ---------------------------------------------------------------
# SIEM Outputs — set each to true to enable
# ---------------------------------------------------------------

# --- Elasticsearch / Elastic Security --------------------------
SIEM_ELASTIC_ENABLED=false
ELASTIC_HOST=https://my-elastic-cluster.example.com
ELASTIC_PORT=9200
ELASTIC_SCHEME=https
ELASTIC_INDEX=zerto-siem-bridge
# Use either user+password OR api_key (api_key takes precedence)
ELASTIC_USER=
ELASTIC_PASSWORD=
ELASTIC_API_KEY=

# --- Splunk (HTTP Event Collector) -----------------------------
SIEM_SPLUNK_ENABLED=false
SPLUNK_HEC_URL=https://splunk.example.com:8088
SPLUNK_HEC_TOKEN=
SPLUNK_INDEX=zerto
SPLUNK_SOURCE=zerto:syslog
SPLUNK_SOURCETYPE=zerto:event

# --- Microsoft Sentinel (Log Analytics Workspace) --------------
SIEM_SENTINEL_ENABLED=false
SENTINEL_WORKSPACE_ID=
SENTINEL_WORKSPACE_KEY=
SENTINEL_LOG_TYPE=ZertoEvents

# --- SentinelOne XDR (HTTP ingest) ----------------------------
SIEM_SENTINELONE_ENABLED=false
S1_INGEST_URL=https://ingest.sentinelone.net/services/collector
S1_API_TOKEN=
